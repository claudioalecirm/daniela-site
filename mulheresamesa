<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mulheres à Mesa — 1ª Edição</title>
  <meta name="description" content="Um ambiente carregado de intenção e propósito. Reserve seu lugar — 18 de julho, Gleba Palhano, Londrina." />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Cinzel:wght@400;500;600&family=Lato:wght@300;400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --creme:   #F0E8D8;
      --creme-m: #FAF6EE;
      --bege:    #D4C4A0;
      --verde:   #3D4A2E;
      --verde-d: #2D3821;
      --verde-p: #6B8050;
      --ouro:    #B8973A;
      --ouro-l:  #D4AF5A;
    }

    html, body {
      background: var(--creme);
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 2rem 1rem 3rem;
    }

    .card {
      background: var(--creme);
      border-radius: 18px;
      overflow: hidden;
      width: 100%;
      max-width: 560px;
      box-shadow: 0 8px 40px rgba(61,74,46,0.10);
    }

    /* ── HERO ── */
    .hero {
      background: var(--creme);
      padding: 2.8rem 2rem 1.8rem;
      text-align: center;
      border-bottom: 1px solid var(--bege);
    }

    .logo-wrap img { display: block; margin: 0 auto; }

    /* Texto "Seu lugar foi preparado" */
    .tagline {
      font-family: 'Lato', sans-serif;
      font-size: 10px;
      letter-spacing: 5px;
      color: var(--verde);
      text-transform: uppercase;
      opacity: 0.6;
      margin: 0.8rem 0 1.4rem;
    }

    /* ── TEXTO DE AMBIENTE ── */
    .ambiente {
      margin: 0 auto 1.6rem;
      max-width: 420px;
      padding: 0 0.5rem;
    }

    .ambiente p {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16.5px;
      font-weight: 400;
      font-style: italic;
      line-height: 1.85;
      color: var(--verde);
      opacity: 0.82;
      text-align: center;
    }

    .ambiente strong {
      font-weight: 600;
      font-style: normal;
      color: var(--ouro);
      opacity: 1;
    }

    /* ── GRID DE INFORMAÇÕES ── */
    .info-grid {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      border: 1px solid var(--bege);
      border-radius: 10px;
      overflow: hidden;
      background: var(--creme-m);
      margin: 0 0 0.9rem;
    }

    .info-item {
      flex: 1;
      min-width: 80px;
      padding: 0.75rem 0.4rem;
      border-right: 1px solid var(--bege);
      text-align: center;
    }

    .info-item:last-child { border-right: none; }

    .info-label {
      display: block;
      font-family: 'Lato', sans-serif;
      font-size: 8px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--ouro);
      margin-bottom: 4px;
    }

    .info-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 15px;
      font-weight: 600;
      color: var(--verde);
      line-height: 1.2;
    }

    /* ── PILARES ── */
    .pillars {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      margin: 0.6rem 0 0.9rem;
    }

    .pillar {
      font-family: 'Lato', sans-serif;
      font-size: 9px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--verde);
      opacity: 0.5;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .pillar-dot {
      width: 3px; height: 3px;
      border-radius: 50%;
      background: var(--ouro);
      opacity: 1;
      flex-shrink: 0;
    }

    /* ── DÚVIDAS ── */
    .duvida {
      margin-top: 1rem;
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      color: var(--verde);
      opacity: 0.65;
    }

    .duvida a {
      color: var(--ouro);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* ── FORMULÁRIO ── */
    .form-section {
      background: var(--creme-m);
      padding: 2rem 2rem 1.5rem;
    }

    .form-header { text-align: center; margin-bottom: 1.4rem; }

    .form-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 500;
      color: var(--verde);
      margin-bottom: 0.25rem;
    }

    .form-sub {
      font-family: 'Lato', sans-serif;
      font-size: 11px;
      letter-spacing: 1px;
      color: var(--verde);
      opacity: 0.45;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 0 0 1.4rem;
    }

    .divider-line { flex: 1; height: 1px; background: var(--bege); }
    .divider-star { color: var(--ouro); font-size: 11px; opacity: 0.7; }

    .field { margin-bottom: 1rem; }

    .field-label {
      display: block;
      font-family: 'Lato', sans-serif;
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--verde);
      opacity: 0.55;
      margin-bottom: 6px;
    }

    input, select {
      width: 100%;
      background: var(--creme);
      border: 1px solid var(--bege);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      color: var(--verde);
      outline: none;
      transition: border-color 0.2s;
      appearance: none;
      -webkit-appearance: none;
    }

    input:focus, select:focus { border-color: var(--ouro); }
    input::placeholder { color: var(--verde); opacity: 0.3; }

    .select-wrap { position: relative; }

    .select-arrow {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      color: var(--ouro);
      font-size: 13px;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .field-error {
      font-family: 'Lato', sans-serif;
      font-size: 11px;
      color: #993C1D;
      margin-top: 4px;
      display: none;
    }

    .field.has-error input,
    .field.has-error select { border-color: #D85A30; }

    .field.has-error .field-error { display: block; }

    /* ── BOTÃO — sempre sólido, nunca transparente ── */
    .btn-inscricao {
      display: block;
      width: 100%;
      margin-top: 1.6rem;
      padding: 18px 16px;
      background: var(--verde);
      border: none;
      border-radius: 10px;
      cursor: pointer;
      text-align: center;
      transition: background 0.15s;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      user-select: none;
      /* garante visível em qualquer dispositivo */
      -webkit-appearance: none;
    }

    .btn-inscricao:hover  { background: var(--verde-d); }

    /* feedback de toque — fica verde oliva ao pressionar */
    .btn-inscricao:active,
    .btn-inscricao.pressed { background: var(--verde-p); }

    .btn-inscricao:disabled { opacity: 0.75; cursor: default; }

    .btn-ornament {
      display: block;
      font-family: 'Lato', sans-serif;
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--ouro);
      margin-bottom: 3px;
    }

    .btn-label {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 21px;
      font-weight: 600;
      color: var(--creme);
      letter-spacing: 0.5px;
    }

    /* ── SUCESSO ── */
    .success-section {
      display: none;
      background: var(--creme-m);
      padding: 3rem 2rem;
      text-align: center;
    }

    .success-icon { margin-bottom: 1.2rem; }

    .success-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 500;
      color: var(--verde);
      margin-bottom: 0.6rem;
    }

    .success-text {
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      line-height: 1.85;
      color: var(--verde);
      opacity: 0.6;
    }

    /* ── FOOTER ── */
    .footer {
      background: var(--creme-m);
      border-top: 1px solid var(--bege);
      padding: 1rem 2rem 1.4rem;
      text-align: center;
    }

    .footer-text {
      font-family: 'Lato', sans-serif;
      font-size: 10px;
      letter-spacing: 1.5px;
      color: var(--verde);
      opacity: 0.35;
    }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--verde);
      color: var(--creme);
      padding: 12px 24px;
      border-radius: 8px;
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      transition: transform 0.3s ease;
      z-index: 999;
      white-space: nowrap;
      pointer-events: none;
    }

    .toast.show { transform: translateX(-50%) translateY(0); }

    /* ── RESPONSIVO ── */
    @media (max-width: 480px) {
      html, body { padding: 0; }
      .card { border-radius: 0; max-width: 100%; min-height: 100vh; box-shadow: none; }
      .hero { padding: 2rem 1.2rem 1.4rem; }
      .form-section { padding: 1.6rem 1.2rem 1.4rem; }
      .row { grid-template-columns: 1fr; }
      .info-item { min-width: 70px; }
      .info-value { font-size: 13px; }
      .ambiente p { font-size: 15.5px; }
    }
  </style>
</head>
<body>

<div class="card">

  <!-- ── HERO ── -->
  <div class="hero">

    <!-- LOGO SVG fiel à imagem: Mulheres verde + "a" itálico dourado + Mesa dourado + ramo de folhas -->
    <div class="logo-wrap">
      <img
        src="data:image/png;base64,"
        alt="Mulheres à Mesa"
        style="display:block;margin:0 auto;max-width:300px;width:100%;mix-blend-mode:multiply;"
      />
    </div>

    <!-- Tagline -->
    <p class="tagline">Seu lugar foi preparado</p>

    <!-- ── TEXTO DE AMBIENTE ── -->
    <div class="ambiente">
      <p>
        Um ambiente carregado de intenção e propósito,<br>
        que vai além de uma simples reunião.<br><br>
        Mulheres que carregam um chamado —<br>
        a ser <strong>referência</strong> no que fazem e onde passam.<br><br>
        Uma mesa de <strong>clareza e posicionamento</strong><br>
        para potencializar sua essência,<br>
        conectando você à fonte certa: <strong>Deus.</strong>
      </p>
    </div>

    <!-- ── GRID DE INFORMAÇÕES ── -->
    <div class="info-grid">
      <div class="info-item">
        <span class="info-label">Edição</span>
        <span class="info-value">1ª</span>
      </div>
      <div class="info-item">
        <span class="info-label">Data</span>
        <span class="info-value">18 de julho</span>
      </div>
      <div class="info-item">
        <span class="info-label">Horário</span>
        <span class="info-value">14h · sábado</span>
      </div>
      <div class="info-item">
        <span class="info-label">Local</span>
        <span class="info-value">Gleba Palhano</span>
      </div>
      <div class="info-item">
        <span class="info-label">Acesso</span>
        <span class="info-value">R$&nbsp;70,00</span>
      </div>
    </div>

    <!-- Pilares -->
    <div class="pillars">
      <span class="pillar"><span class="pillar-dot"></span>Identidade</span>
      <span class="pillar"><span class="pillar-dot"></span>Fé</span>
      <span class="pillar"><span class="pillar-dot"></span>Família</span>
      <span class="pillar"><span class="pillar-dot"></span>Propósito</span>
    </div>

    <!-- Dúvidas -->
    <p class="duvida">
      Dúvidas?
      <a href="https://wa.me/5543984059471?text=Ol%C3%A1%20Daniela%2C%20quero%20mais%20informa%C3%A7%C3%B5es%20sobre%20o%20Mulheres%20%C3%A0%20Mesa" target="_blank" rel="noopener">
        Clique aqui
      </a>
      e fale com a Daniela pelo WhatsApp.
    </p>
  </div>

  <!-- ── FORMULÁRIO ── -->
  <div class="form-section" id="form-section">
    <div class="form-header">
      <p class="form-title">Reserve seu lugar à mesa</p>
      <p class="form-sub">Preencha seus dados para confirmar a inscrição</p>
    </div>

    <div class="divider">
      <div class="divider-line"></div>
      <span class="divider-star">✦</span>
      <div class="divider-line"></div>
    </div>

    <div class="field" id="field-nome">
      <label class="field-label" for="nome">Nome completo</label>
      <input type="text" id="nome" placeholder="Seu nome completo" autocomplete="name" />
      <span class="field-error">Por favor, informe seu nome completo.</span>
    </div>

    <div class="row">
      <div class="field" id="field-idade">
        <label class="field-label" for="idade">Idade</label>
        <input type="number" id="idade" placeholder="Ex: 32" min="1" max="120" />
        <span class="field-error">Informe sua idade.</span>
      </div>
      <div class="field" id="field-cidade">
        <label class="field-label" for="cidade">Cidade</label>
        <input type="text" id="cidade" placeholder="Sua cidade" />
        <span class="field-error">Informe sua cidade.</span>
      </div>
    </div>

    <div class="row">
      <div class="field" id="field-estado_civil">
        <label class="field-label" for="estado_civil">Estado civil</label>
        <div class="select-wrap">
          <select id="estado_civil">
            <option value="">Selecione...</option>
            <option>Solteira</option>
            <option>Casada</option>
            <option>Divorciada</option>
            <option>Viúva</option>
            <option>União estável</option>
          </select>
          <span class="select-arrow">▾</span>
        </div>
        <span class="field-error">Selecione seu estado civil.</span>
      </div>
      <div class="field" id="field-profissao">
        <label class="field-label" for="profissao">Profissão</label>
        <input type="text" id="profissao" placeholder="Sua profissão" />
        <span class="field-error">Informe sua profissão.</span>
      </div>
    </div>

    <!-- BOTÃO — sempre sólido, nunca transparente -->
    <button class="btn-inscricao" id="btn-inscricao" type="button">
      <span class="btn-ornament">✦ confirmar presença ✦</span>
      <span class="btn-label" id="btn-label">Finalizar minha inscrição</span>
    </button>
  </div>

  <!-- ── SUCESSO ── -->
  <div class="success-section" id="success-section">
    <div class="success-icon">
      <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="26" cy="26" r="24" stroke="#B8973A" stroke-width="1.5" fill="none"/>
        <path d="M16 26 L23 33 L36 19" stroke="#B8973A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>
    <p class="success-title">Inscrição enviada!</p>
    <p class="success-text">
      Seus dados foram salvos com sucesso.<br>
      O WhatsApp da Daniela foi aberto com sua mensagem —<br>
      basta enviar para garantir seu lugar à mesa. 🌿
    </p>
  </div>

  <!-- ── FOOTER ── -->
  <div class="footer">
    <p class="footer-text">Mulheres à Mesa &nbsp;·&nbsp; 1ª Edição &nbsp;·&nbsp; Londrina — PR</p>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  const SUPABASE_URL = 'https://bkuegmkpcasybistzogz.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJrdWVnbWtwY2FzeWJpc3R6b2d6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIzNTM4MjIsImV4cCI6MjA5NzkyOTgyMn0.vV1yJ8vBScHQ-fQVxtur6eWywHAuJ25BeY2gEh-BKRM';
  const WHATSAPP = '5543984059471';

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
  }

  function validate() {
    const ids = ['nome', 'idade', 'cidade', 'estado_civil', 'profissao'];
    let ok = true;
    ids.forEach(id => {
      const el  = document.getElementById(id);
      const wrap = document.getElementById('field-' + id);
      if (!el.value.trim()) { wrap.classList.add('has-error'); ok = false; }
      else wrap.classList.remove('has-error');
    });
    return ok;
  }

  async function salvarSupabase(dados) {
    try {
      const r = await fetch(SUPABASE_URL + '/rest/v1/inscricoes', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': 'Bearer ' + SUPABASE_KEY,
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify(dados)
      });
      return r.ok;
    } catch(e) { return false; }
  }

  const btn   = document.getElementById('btn-inscricao');
  const label = document.getElementById('btn-label');

  btn.addEventListener('click', async () => {
    if (!validate()) {
      showToast('Preencha todos os campos para continuar.');
      return;
    }

    // Feedback visual imediato de clique
    btn.classList.add('pressed');
    label.textContent = 'Salvando...';
    btn.disabled = true;

    const nome        = document.getElementById('nome').value.trim();
    const idade       = parseInt(document.getElementById('idade').value.trim(), 10);
    const cidade      = document.getElementById('cidade').value.trim();
    const estado_civil = document.getElementById('estado_civil').value.trim();
    const profissao   = document.getElementById('profissao').value.trim();

    const salvo = await salvarSupabase({ nome, idade, cidade, estado_civil, profissao });

    // Monta mensagem para WhatsApp
    const msg = encodeURIComponent(
      'Olá, Daniela! 🌿 Gostaria de confirmar minha inscrição no *Mulheres à Mesa — 1ª Edição*!\n\n' +
      '✨ *Meus dados:*\n' +
      '👤 Nome: '          + nome        + '\n' +
      '🎂 Idade: '         + idade       + ' anos\n' +
      '📍 Cidade: '        + cidade      + '\n' +
      '💍 Estado civil: '  + estado_civil + '\n' +
      '💼 Profissão: '     + profissao   + '\n\n' +
      'Aguardo as informações para confirmar meu lugar. 💛'
    );

    // Exibe tela de sucesso
    document.getElementById('form-section').style.display = 'none';
    document.getElementById('success-section').style.display = 'block';

    if (!salvo) showToast('Dados enviados ao WhatsApp. Falha ao salvar online.');

    // Abre WhatsApp após breve delay
    setTimeout(() => {
      window.open('https://wa.me/' + WHATSAPP + '?text=' + msg, '_blank');
    }, 700);
  });

  // Remove erro ao digitar
  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', () => {
      const wrap = el.closest('.field');
      if (el.value.trim()) wrap.classList.remove('has-error');
    });
  });
</script>
</body>
</html>
